"address\",\"name\":\"holder\",\"type\":\"address\"}],\"name\":\"pending\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"Protofire\",\"errors\":{\"SafeERC20FailedOperation(address)\":[{\"details\":\"An operation with an ERC-20 token failed.\"}]},\"events\":{\"Claimed(address,uint256)\":{\"params\":{\"amount\":\"Cantidad de USDC reclamada.\",\"holder\":\"Direcci\\u00f3n del holder que reclama.\"}},\"Distributed(uint256,uint256)\":{\"params\":{\"dividendPerToken\":\"Valor del acumulador global.\",\"usdcAmount\":\"Cantidad de USDC depositada.\"}}},\"kind\":\"dev\",\"methods\":{\"claim()\":{\"details\":\"Actualiza el acumulador del holder antes de transferir         para evitar reentrancy.\"},\"constructor\":{\"params\":{\"_dpf\":\"Direcci\\u00f3n del token DPF del proyecto.\",\"_issuer\":\"Direcci\\u00f3n del emisor del proyecto.\",\"_offering\":\"Direcci\\u00f3n del contrato Offering del proyecto.\",\"_usdc\":\"Direcci\\u00f3n del token USDC.\"}},\"distribute(uint256)\":{\"details\":\"Solo puede llamarse despu\\u00e9s de que el Offering haya cerrado exitosamente.         Puede llamarse m\\u00faltiples veces a medida que el proyecto genera ganancias.\",\"params\":{\"usdcAmount\":\"Cantidad de USDC a distribuir (6 decimales).\"}},\"pending(address)\":{\"params\":{\"holder\":\"Direcci\\u00f3n del holder a consultar.\"},\"returns\":{\"_0\":\"Cantidad de USDC pendiente de reclamar.\"}}},\"title\":\"Dividends\",\"version\":1},\"userdoc\":{\"events\":{\"Claimed(address,uint256)\":{\"notice\":\"Se emite cuando un holder reclama sus dividendos.\"},\"Distributed(uint256,uint256)\":{\"notice\":\"Se emite cuando el issuer deposita dividendos.\"}},\"kind\":\"user\",\"methods\":{\"DPF()\":{\"notice\":\"Token DPF del proyecto cuyos holders reciben dividendos.\"},\"ISSUER()\":{\"notice\":\"Direcci\\u00f3n del issuer, \\u00fanico autorizado a distribuir dividendos.\"},\"OFFE